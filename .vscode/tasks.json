{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "esp32Port",
      "type": "promptString",
      "description": "Puerto serial del ESP32 (ej: COM3, COM4, /dev/ttyUSB0)",
      "default": "COM4"
    }
  ],
  "tasks": [
    {
      "label": "Arduino: Compilar ESP32-C6 (huge_app)",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "compile",
        "--fqbn",
        "esp32:esp32:esp32c6:PartitionScheme=huge_app",
        "${workspaceFolder}/03_firmware/mochi_unified_5"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Arduino: Subir al ESP32-C6",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "upload",
        "-p",
        "${input:esp32Port}",
        "--fqbn",
        "esp32:esp32:esp32c6:PartitionScheme=huge_app",
        "${workspaceFolder}/03_firmware/mochi_unified_5"
      ],
      "problemMatcher": []
    },
    {
      "label": "Arduino: Monitor Serial (115200)",
      "type": "shell",
      "command": "arduino-cli",
      "args": [
        "monitor",
        "-p",
        "${input:esp32Port}",
        "-b",
        "esp32:esp32:esp32c6:PartitionScheme=huge_app",
        "-c",
        "baudrate=115200"
      ],
      "problemMatcher": []
    },
    {
      "label": "Arduino: Compilar + Subir",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Arduino: Compilar ESP32-C6 (huge_app)",
        "Arduino: Subir al ESP32-C6"
      ],
      "problemMatcher": []
    }
  ]
}
