# ── Herramientas internas (no relevante para estudiantes) ──────────────────
.claude/

# ── Salida de compilación de Arduino CLI ───────────────────────────────────
build/
*.elf
*.hex
*.map
*.bin.gz

# ── Credenciales (si se externalizan en el futuro) ─────────────────────────
secrets.h
credentials.h
.env

# ── Página web (dependencias generadas) ────────────────────────────────────
04_pagina_web/node_modules/
04_pagina_web/dist/
04_pagina_web/.next/
04_pagina_web/.nuxt/

# ── Sistema operativo ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Convertidor de GIFs (archivos generados, no subir al repo) ─────────────
herramientas/convertidor_gifs/data/
herramientas/convertidor_gifs/*/          # carpetas de frames generadas por gif.exe
!herramientas/convertidor_gifs/README.md  # mantener el README aunque la carpeta esté vacía

# ── GIFs fuente (binarios grandes — usar Git LFS o gestionar localmente) ────
# Descomenta la siguiente línea si NO quieres rastrear los GIFs en git:
# recursos/gifs/*.gif

# ── Logs y temporales ──────────────────────────────────────────────────────
*.log
*.tmp
